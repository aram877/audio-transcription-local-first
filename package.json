{
  "name": "audio-transcription",
  "version": "0.1.0",
  "description": "Desktop app: record or import audio, transcribe locally with Whisper, and summarize with an LLM.",
  "main": "out/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dist": "electron-vite build && electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "38.8.6",
    "electron-builder": "^24.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@huggingface/transformers": "^3.0.0"
  },
  "build": {
    "appId": "io.aram877.audio-transcription",
    "productName": "Audio Transcription",
    "files": [
      "out/**/*",
      "package.json",
      "!node_modules/@huggingface/transformers/.cache/**"
    ],
    "asarUnpack": [
      "**/onnxruntime-node/**",
      "**/onnxruntime-web/**",
      "**/@huggingface/transformers/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
